{
  "name": "fenster-price-radar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "banner:check": "node --check tools/banner-maker/select-action.mjs && node --check tools/banner-maker/image-meta.mjs && node --check tools/banner-maker/fonts.mjs && node --check tools/banner-maker/banner-template.mjs && node --check tools/banner-maker/render.mjs && node --check tools/banner-maker/compress.mjs && node --check tools/banner-maker/make-banner.mjs && node --check tools/lib/find-chrome.mjs",
    "banner:make": "node tools/banner-maker/make-banner.mjs",
    "predev": "node scripts/build-anleitung.js",
    "dev": "vite --host 0.0.0.0",
    "prebuild": "node scripts/build-anleitung.js",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "data:sync": "node scripts/sync-results.js",
    "trend:build": "node scripts/build-trend-index.js",
    "verify:prices": "node scripts/verify-price-radar.js && node scripts/verify-two-sash-equivalence.js",
    "verify:sample": "node scripts/verify-sample-configs.js",
    "dfs:pvc:mapped": "node src/providers/dfs/price-mapped-pvc.js",
    "fb:pvc:mapped": "node src/providers/fensterblick/price-mapped-pvc.js",
    "fv:pvc:mapped": "node src/providers/fensterversand/price-mapped-pvc.js",
    "eko:pvc:mapped": "node src/providers/eko4u/price-mapped-pvc.js",
    "prices:update": "node scripts/update-prices.js && npm run verify:prices",
    "test:calendar": "node tests/action-calendar.mjs",
    "test:app-shell": "node tests/app-shell.mjs",
    "test:links": "node tests/config-links.mjs",
    "test:verification": "node tests/verification.mjs",
    "test:aufmass": "node tests/aufmass-smoke.mjs",
    "test:banner": "node tests/banner-maker.mjs",
    "check:live": "node scripts/check-live.mjs",
    "test:agent": "node tests/agent-token.mjs",
    "test:mcp": "node tests/mcp-smoke.mjs",
    "test:chatbot": "node tests/chatbot-smoke.mjs && node tests/config-links.mjs && node --check public/chatbot-widget.js",
    "ebook:check": "node --check public/ebooks/ruhiges-heimspiel/export-pdf.js && node --check tools/ebook-maker/make-ebook.mjs",
    "ebook:pdf": "node public/ebooks/ruhiges-heimspiel/export-pdf.js",
    "ebook:make": "node tools/ebook-maker/make-ebook.mjs",
    "knowledge:crawl": "node scripts/crawl-dfs-knowledge.js",
    "rueckhol": "npm --prefix rueckhol-automatik start",
    "rueckhol:test": "npm --prefix rueckhol-automatik test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@vitejs/plugin-react": "6.0.1",
    "lucide-react": "1.11.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "vite": "8.0.10"
  },
  "devDependencies": {
    "sharp": "^0.35.3"
  }
}
