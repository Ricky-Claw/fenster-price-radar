{
  "name": "fenster-price-radar",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "data:sync": "node scripts/sync-results.js",
    "trend:build": "node scripts/build-trend-index.js",
    "verify:prices": "node scripts/verify-price-radar.js && node scripts/verify-two-sash-equivalence.js",
    "dfs:pvc:mapped": "node src/providers/dfs/price-mapped-pvc.js",
    "fb:pvc:mapped": "node src/providers/fensterblick/price-mapped-pvc.js",
    "fv:pvc:mapped": "node src/providers/fensterversand/price-mapped-pvc.js",
    "prices:update": "node scripts/update-prices.js && npm run verify:prices",
    "test:calendar": "node tests/action-calendar.mjs",
    "test:app-shell": "node tests/app-shell.mjs",
    "test:links": "node tests/config-links.mjs",
    "test:verification": "node tests/verification.mjs",
    "test:aufmass": "node tests/aufmass-smoke.mjs",
    "test:chatbot": "node tests/chatbot-smoke.mjs && node tests/config-links.mjs && node --check public/chatbot-widget.js",
    "ebook:check": "node --check public/ebooks/ruhiges-heimspiel/export-pdf.js",
    "ebook:pdf": "node public/ebooks/ruhiges-heimspiel/export-pdf.js",
    "knowledge:crawl": "node scripts/crawl-dfs-knowledge.js",
    "rueckhol": "npm --prefix rueckhol-automatik start",
    "rueckhol:test": "npm --prefix rueckhol-automatik test"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "vite": "latest",
    "react": "latest",
    "react-dom": "latest",
    "lucide-react": "latest"
  },
  "devDependencies": {}
}
