{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm ci",
  "functions": {
    "api/quote.js": {
      "includeFiles": "data/**"
    }
  },
  "rewrites": [
    { "source": "/((?!data/|assets/|api/).*)", "destination": "/index.html" }
  ]
}
